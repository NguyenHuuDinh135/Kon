DB_USER=nguyenhuudinh
DB_PASSWORD=kon_password
DB_NAME=kon_erp_northwind
DATABASE_URL=postgresql://nguyenhuudinh:kon_password@localhost:5432/kon_erp_northwind

# Kaggle dataset downloads (required for ETL)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# JWT & CORS
JWT_SECRET_KEY=your-strong-secret-key-minimum-32-characters-here
CORS_ORIGINS=http://localhost:3000

# LLM & Embeddings — Bedrock primary, Ollama fallback
USE_BEDROCK=true
AWS_REGION=us-west-2
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_EMBEDDING_DIMENSION=1024

# AWS credentials (required for Docker containers to access Bedrock)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Ollama fallback (when Bedrock unavailable)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_LLM_MODEL=qwen2.5
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large
