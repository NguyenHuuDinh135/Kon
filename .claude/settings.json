{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx prettier *)",
      "Bash(npx playwright *)",
      "Bash(npx eslint *)",
      "Bash(npx tsc *)",
      "Bash(docker compose *)",
      "Bash(pytest *)",
      "Bash(ruff *)",
      "Bash(python apps/worker/main.py)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Read",
      "Write",
      "Edit"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "case \"$FILE_PATH\" in *.ts|*.tsx|*.js|*.jsx|*.json|*.css|*.md) npx prettier --write \"$FILE_PATH\" 2>/dev/null ;; *.py) ruff format \"$FILE_PATH\" 2>/dev/null && ruff check --fix \"$FILE_PATH\" 2>/dev/null ;; esac; true"
          }
        ]
      }
    ]
  }
}
